{
  "name": "crumbleco",
  "version": "1.0.0",
  "type": "module",
  "files": [
    "dist",
    "src/**/*.cnd",
    "settings",
    "static"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build && yarn package",
    "clean": "rm -rf dist/",
    "jahia-deploy": "jahia-deploy",
    "package": "yarn pack --out dist/package.tgz",
    "dev": "vite build --watch",
    "watch:callback": "yarn package && yarn jahia-deploy"
  },
  "devDependencies": {
    "@jahia/javascript-modules-library": "^1.2.0",
    "@jahia/vite-plugin": "^1.2.0",
    "@types/react": "^19.1.2",
    "i18next": "^25.0.2",
    "react": "^19.1.0",
    "react-i18next": "^16.1.0",
    "typescript": "^5.8.3",
    "typescript-plugin-css-modules": "^5.1.0",
    "vite": "^7.0.0"
  },
  "packageManager": "yarn@4.10.3",
  "engines": {
    "node": ">=22.0.0"
  },
  "jahia": {
    "name": "crumbleco",
    "snapshot": true,
    "module-dependencies": "default",
    "module-type": "templatesSet",
    "server": "dist/server/index.js",
    "static-resources": "/dist/client,/dist/assets,/images"
  }
}
