name: Release
on:
  push:
    branches:
      - main
  workflow_dispatch: null
jobs:
  prepare-next-release:
    runs-on: ubuntu-slim
    permissions:
      contents: write
      pull-requests: write
    steps:
      - uses: actions/checkout@v6
      - run: npx chachalog@^0.5.0 prepare-next-release
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
  publish-release:
    runs-on: ubuntu-slim
    permissions:
      contents: write
      id-token: write
    steps:
      - uses: actions/checkout@v6
      - uses: jdx/mise-action@v4
      - name: Build and publish
        run: |
          yarn install
          yarn workspaces foreach -vv --all --topological-dev run build
          yarn workspaces foreach -vv --all --topological --no-private npm publish --access public
          --tolerate-republish --provenance
      - run: npx chachalog@^0.5.0 publish-release
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
